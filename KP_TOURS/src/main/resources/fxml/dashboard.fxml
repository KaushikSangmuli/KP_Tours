<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="KP_TOURS.ui.dashboard"
            prefWidth="1400"
            prefHeight="850"
            stylesheets="@../css/app.css">

    <!-- ================================================== -->
    <!-- HEADER SUMMARY -->
    <!-- ================================================== -->

    <top>

    <HBox spacing="15"
          alignment="CENTER_LEFT"
          styleClass="header-container">

    <padding>
        <Insets top="15" right="20" bottom="15" left="20"/>
    </padding>

    <VBox styleClass="summary-card">
        <Label text="Total Trips" styleClass="summary-title"/>
        <Label fx:id="totalTripsLabel"
               text="0"
               styleClass="summary-value"/>
    </VBox>

    <VBox styleClass="summary-card">
        <Label text="Total Sell" styleClass="summary-title"/>
        <Label fx:id="totalSellLabel"
               text="0"
               styleClass="summary-value"/>
    </VBox>

    <VBox styleClass="summary-card">
        <Label text="Total Purchase" styleClass="summary-title"/>
        <Label fx:id="totalPurchaseLabel"
               text="0"
               styleClass="summary-value"/>
    </VBox>

    <VBox styleClass="summary-card">
        <Label text="Total Profit" styleClass="summary-title"/>
        <Label fx:id="totalProfitLabel"
               text="0"
               styleClass="summary-value"/>
    </VBox>

    <VBox styleClass="summary-card">
        <Label text="Pending Trips" styleClass="summary-title"/>
        <Label fx:id="pendingTripsLabel"
               text="0"
               styleClass="summary-value"/>
    </VBox>

    <VBox styleClass="summary-card">
        <Label text="Cancelled Trips" styleClass="summary-title"/>
        <Label fx:id="cancelledTripsLabel"
               text="0"
               styleClass="summary-value"/>
    </VBox>
</BorderPane>